{
    "name": "vue-ts-vite-template",
    "private": true,
    "version": "0.0.0",
    "packageManager": "pnpm@10.13.1",
    "scripts": {
        "dev": "vite",
        "build": "vue-tsc --noEmit && vite build",
        "ai:check": "node scripts/ai-check.mjs",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "preview": "vite preview",
        "typecheck": "vue-tsc --noEmit",
        "e2e": "playwright test",
        "e2e:smoke": "playwright test tests/e2e/login.smoke.spec.ts tests/e2e/menu-list.smoke.spec.ts tests/e2e/permission-route.smoke.spec.ts",
        "e2e:menu": "playwright test tests/e2e/menu-list.smoke.spec.ts",
        "e2e:module": "playwright test tests/e2e/module-regression.spec.ts",
        "e2e:ui": "playwright test --ui",
        "e2e:headed": "playwright test --headed",
        "e2e:report": "playwright show-report",
        "playwright:install": "playwright install chromium"
    },
    "dependencies": {
        "@arco-design/web-vue": "^2.57.0",
        "axios": "^1.13.6",
        "dayjs": "^1.11.20",
        "echarts": "^6.0.0",
        "lodash-es": "^4.17.23",
        "md5": "^2.3.0",
        "nprogress": "^0.2.0",
        "pinia": "^3.0.4",
        "vue": "^3.5.30",
        "vue-i18n": "^11.3.0",
        "vue-qr": "^5.0.3",
        "vue-request": "^2.0.4",
        "vue-router": "^5.0.4"
    },
    "devDependencies": {
        "@intlify/unplugin-vue-i18n": "^11.1.1",
        "@playwright/test": "^1.59.1",
        "@types/lodash-es": "^4.17.12",
        "@types/md5": "^2.3.6",
        "@types/node": "^25.5.0",
        "@types/nprogress": "^0.2.3",
        "@typescript-eslint/eslint-plugin": "^8.57.1",
        "@typescript-eslint/parser": "^8.57.1",
        "@vitejs/plugin-vue": "^6.0.5",
        "autoprefixer": "^10.4.27",
        "eslint": "^10.0.3",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-vue": "^10.8.0",
        "globals": "^15.15.0",
        "less": "^4.6.4",
        "postcss": "^8.5.8",
        "prettier": "^3.8.1",
        "sass": "^1.98.0",
        "tailwindcss": "^3.4.19",
        "typescript": "^5.9.3",
        "unplugin-auto-import": "^21.0.0",
        "unplugin-vue-components": "^31.0.0",
        "vite": "^8.0.0",
        "vue-eslint-parser": "^10.0.0",
        "vue-tsc": "^3.2.6"
    }
}
